{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mettle Optimization Report",
  "scopeName": "source.mettle-explain",
  "patterns": [
    {
      "comment": "Section headers: -- optimization report: file ----------",
      "match": "^(--|\\u2500\\u2500) (optimization report|backend report): (\\S+).*$",
      "captures": {
        "2": { "name": "markup.heading.mettle-explain" },
        "3": { "name": "entity.name.section.mettle-explain markup.bold" }
      }
    },
    {
      "comment": "Positive remark headlines (vectorized / inlined / unrolled / verified @noalloc)",
      "match": "^  (\\S+) (\\(.+?\\)): ((?:vectorized|inlined|fully unrolled|eliminated|hoisted|verified @noalloc).*)$",
      "captures": {
        "1": { "name": "entity.name.function.mettle-explain" },
        "2": { "name": "comment.line.mettle-explain" },
        "3": { "name": "string.regexp.mettle-explain markup.inserted" }
      }
    },
    {
      "comment": "Negative remark headlines (NOT vectorized / NOT inlined)",
      "match": "^  (\\S+) (\\(.+?\\)): (NOT .*)$",
      "captures": {
        "1": { "name": "entity.name.function.mettle-explain" },
        "2": { "name": "comment.line.mettle-explain" },
        "3": { "name": "invalid.deprecated.mettle-explain markup.deleted" }
      }
    },
    {
      "comment": "verified: lines are the report's proofs",
      "match": "^      (\\\\_|\\u2514) (verified):(.*)$",
      "captures": {
        "2": { "name": "markup.inserted.mettle-explain markup.bold" },
        "3": { "name": "markup.inserted.mettle-explain" }
      }
    },
    {
      "comment": "reason / fix / calls / consequence sublines",
      "match": "^      (\\\\_|\\u2514) (reason|fix|calls|consequence):(.*)$",
      "captures": {
        "2": { "name": "keyword.other.mettle-explain" },
        "3": { "name": "comment.block.documentation.mettle-explain" }
      }
    },
    {
      "comment": "Backend coverage summary lines",
      "match": "^  (\\d+/\\d+ functions reaching codegen.*|[\\d.]+% of the program's .*|\\d+ functions? use baseline.*)$",
      "name": "markup.heading.mettle-explain"
    },
    {
      "comment": "Backend bail-group headers (reason (N functions, M instructions):)",
      "match": "^  (.+) (\\(\\d+ functions?, \\d+ instructions\\)):$",
      "captures": {
        "1": { "name": "keyword.other.mettle-explain" },
        "2": { "name": "comment.line.mettle-explain" }
      }
    },
    {
      "comment": "Backtick-quoted identifiers anywhere (kernels, callees, decorators)",
      "match": "`[^`]+`",
      "name": "variable.other.constant.mettle-explain"
    },
    {
      "comment": "Source locations",
      "match": "@ line \\d+|lines \\d+-\\d+",
      "name": "constant.numeric.mettle-explain"
    }
  ]
}
