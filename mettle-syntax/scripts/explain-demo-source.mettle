// Demo for --explain: a mix of loops and calls the optimizer treats differently.

fn scale(x: float32) -> float32 {
    return x * 2.5;
}

fn opaque(x: int32) -> int32 {
    return x + 1;
}

fn saxpy(a: float32, x: float32*, y: float32*, n: int32) {
    for i in 0..n {
        y[i] = a * x[i] + y[i];
    }
}

fn with_call(out: float32*, n: int32) {
    var i: int32 = 0;
    while (i < n) {
        out[i] = scale(out[i]);
        i = i + 1;
    }
}

fn sum_bytes(data: uint8*, n: int32) -> int32 {
    var total: int32 = 0;
    for i in 0..n {
        total = total + (int32)data[i];
    }
    return total;
}

// Row-times-vector: the inner dot product vectorizes, the outer row loop
// stays scalar and drives it.
fn matvec(m: float32*, x: float32*, y: float32*, rows: int32, cols: int32) {
    for r in 0..rows {
        var acc: float32 = 0.0;
        for c in 0..cols {
            acc = acc + m[r * cols + c] * x[c];
        }
        y[r] = acc;
    }
}

fn tiny_fixed() -> int32 {
    var s: int32 = 0;
    for i in 0..8 {
        s = s + i * i;
    }
    return s;
}

// `@pure` + loop-invariant argument: the call is hoisted out of the loop
// (`@noinline` keeps it a real call so LICM, not the inliner, handles it).
fn bias(k: int32) -> int32 {
    return k * 3 + 1;
}

fn apply_bias(a: int32*, n: int32, k: int32) -> int32 {
    var s: int32 = 0;
    for i in 0..n {
        s = s + a[i] + bias(k);
    }
    return s;
}

// `@noalloc`: proven allocation-free over everything it can reach.
fn norm2(x: float32, y: float32) -> float32 {
    return x * x + y * y;
}

// int32 sum into an int32 accumulator: the kernel needs int64; the fix is
// simulated and proven (-> vpaddd).
fn sum_ints(a: int32*, n: int32) -> int32 {
    var s: int32 = 0;
    for i in 0..n {
        s = s + a[i];
    }
    return s;
}

// int16 elements have no kernel; "use int32 + int64 accumulator" is simulated
// and proven.
fn sum_shorts(a: int16*, n: int32) -> int32 {
    var s: int64 = 0;
    for i in 0..n {
        s = s + (int32)a[i];
    }
    return s;
}

// `@noinline` on the callee blocks the loop; the report simulates REMOVING
// the veto, re-runs the inliner, and proves the loop then vectorizes.
fn damp(x: float32) -> float32 {
    return x * 0.5;
}

fn apply_damp(a: float32*, n: int32) {
    for i in 0..n {
        a[i] = damp(a[i]);
    }
}

// The non-counter index half mutates each iteration: the row-pointer advice
// is provably unwritable, so the report REPLACES it instead of printing it.
fn skew(m: float32*, v: float32*, n: int32) -> float32 {
    var acc: float32 = 0.0;
    var k: int32 = 0;
    for c in 0..n {
        acc = acc + m[k + c] * v[c];
        k = k + 2;
    }
    return acc;
}

fn step1(x: float32) -> float32 {
    return x + 1.0;
}

// Refused by the call-count cap -- but the report re-checks with @inline
// pretend-applied and proves the suggestion before printing it.
fn chain(x: float32) -> float32 {
    return step1(step1(step1(x)));
}

fn main() -> int32 {
    var xs: float32[64];
    var ys: float32[64];
    var bs: uint8[64];
    var mm: float32[256];
    var i: int32 = 0;
    while (i < 64) {
        xs[i] = (float32)i;
        ys[i] = 1.0;
        bs[i] = (uint8)i;
        i = i + 1;
    }
    i = 0;
    while (i < 256) {
        mm[i] = 0.5;
        i = i + 1;
    }
    saxpy(2.0, &xs[0], &ys[0], 64);
    with_call(&ys[0], 64);
    matvec(&mm[0], &xs[0], &ys[0], 4, 64);
    var iv: int32[64];
    i = 0;
    while (i < 64) { iv[i] = i; i = i + 1; }
    var t: int32 = sum_bytes(&bs[0], 64) + apply_bias(&iv[0], 64, 7);
    var sh: int16[64];
    i = 0;
    while (i < 64) { sh[i] = (int16)i; i = i + 1; }
    t = t + sum_ints(&iv[0], 64) + sum_shorts(&sh[0], 64);
    apply_damp(&ys[0], 64);
    var nf: float32 = norm2(3.0, 4.0) + chain(1.0) + skew(&mm[0], &xs[0], 32);
    var u: int32 = opaque(t + tiny_fixed() + (int32)nf);
    return u - u;
}
