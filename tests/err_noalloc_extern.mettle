// `@noalloc` is a proof: an extern we cannot see into cannot be proven
// allocation-free, so calling it violates the contract.
extern fn mystery(x: int32) -> int32 = "rand";
@noalloc fn hot(x: int32) -> int32 {
    return mystery(x) + 1;
}
fn main() -> int32 {
    return hot(1) - hot(1);
}
