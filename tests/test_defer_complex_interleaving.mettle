import "std/io";

fn a() { puts(cstr("A\n")); }
fn b() { puts(cstr("B\n")); }
fn c() { puts(cstr("C\n")); }
fn d() { puts(cstr("D\n")); }
fn e() { puts(cstr("E\n")); }
fn f() { puts(cstr("F\n")); }

fn main() -> int32 {
  defer a();
  defer b();
  {
    defer c();
    {
      defer d();
      defer e();
    }
    defer f();
  }
  return 0;
}
