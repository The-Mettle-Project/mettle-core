struct Tiny1 {
  a: uint8;
}

struct Tiny2 {
  a: uint16;
}

struct Small4 {
  a: int32;
}

struct Small8 {
  a: int32;
  b: int32;
}

struct Big3 {
  a: int32;
  b: int32;
  c: int32;
}

fn Tiny1_value(v: Tiny1) -> int32 {
  return (int32)v.a;
}

fn Tiny2_value(v: Tiny2) -> int32 {
  return (int32)v.a;
}

fn Small4_value(v: Small4) -> int32 {
  return v.a;
}

fn Small8_sum(v: Small8) -> int32 {
  return v.a + v.b;
}

fn Big3_total(v: Big3) -> int32 {
  return v.a + v.b + v.c;
}

fn Big3_total_ptr(v: Big3*) -> int32 {
  return v->a + v->b + v->c;
}

fn main() -> int32 {
  var t1: Tiny1;
  t1.a = (uint8)7;
  if (t1.value() != 7) {
    return 1;
  }

  var t2: Tiny2;
  t2.a = (uint16)9;
  if (t2.value() != 9) {
    return 2;
  }

  var s4: Small4;
  s4.a = 11;
  if (s4.value() != 11) {
    return 3;
  }

  var s8: Small8;
  s8.a = 13;
  s8.b = 17;
  if (s8.sum() != 30) {
    return 4;
  }

  var big: Big3;
  big.a = 19;
  big.b = 23;
  big.c = 29;
  if (big.total() != 71) {
    return 5;
  }

  var ptr: Big3* = &big;
  if (ptr.total_ptr() != 71) {
    return 6;
  }

  return 0;
}
