import "std/io";

fn iter_err() { puts(cstr("ITER_ERR\n")); }
fn iter_ok() { puts(cstr("ITER_OK\n")); }
fn loop_err() { puts(cstr("LOOP_ERR\n")); }
fn loop_ok() { puts(cstr("LOOP_OK\n")); }
fn outer_err() { puts(cstr("OUTER_ERR\n")); }
fn outer_ok() { puts(cstr("OUTER_OK\n")); }

fn main() -> int32 {
  errdefer outer_err();
  defer outer_ok();

  var i: int32 = 0;
  while (i < 3) {
    errdefer loop_err();
    defer loop_ok();

    if (i == 1) {
      i = i + 1;
      continue;
    }

    {
      errdefer iter_err();
      defer iter_ok();
      if (i == 2) {
        break;
      }
    }

    i = i + 1;
  }

  return 0;
}
