// ABI: function pointer / indirect call — same convention
// We test by calling through a known function (no function pointers in Mettle)
// This verifies chained calls preserve ABI
fn f1(x: int32) -> int32 {
  return x * 2;
}

fn f2(y: int32) -> int32 {
  return f1(y) + 1;
}

fn main() -> int32 {
  var r: int32 = f2(7);
  if (r == 15) {
    return 1;
  }
  return 0;
}
