// Regression for a silent CPU-backend miscompile: in a large/complex function
// that bails the MIR backend to the fallback expression-chain emitters, a uint32
// value (loaded from a uint32*) used for div/mod/right-shift or widened with
// (int64) was tracked as SIGNED int32 -- emitting IDIV/SAR and a sign-extending
// load, so a high-bit-set uint32 (0x9E3779B1) computed with signed semantics.
//
// This is a host-side replica of examples/llm/qwen3/gpu/dgpu_check.mettle's main
// (GPU calls stubbed) with the k_u32 reference math INLINED -- the exact shape
// that mis-tracked. main's size/complexity is the trigger, so the full structure
// is preserved. The inline results are checked against the SAME math in tiny
// helper functions that stay on the (correct) MIR backend; a divergence means
// the fallback mis-tracked the uint32 as signed. Returns 0 on success.
import "std/io";
import "std/mem";

// --- stubs replacing the CUDA externs (no GPU) ---
fn cuInit(flags: uint32) -> int32 { return 0; }
fn cuDeviceGet(dev: int32*, ordinal: int32) -> int32 { dev[0] = 0; return 0; }
fn cuCtxCreate_v2(pctx: int64*, flags: uint32, dev: int32) -> int32 { pctx[0] = 1; return 0; }
fn cuModuleLoadData(modOut: int64*, image: uint8*) -> int32 { modOut[0] = 1; return 0; }
fn cuModuleGetFunction(kfOut: int64*, mod: int64, name: cstring) -> int32 { kfOut[0] = 1; return 0; }
fn cuMemAlloc_v2(dptr: int64*, bytes: int64) -> int32 { dptr[0] = (int64)malloc(bytes); return 0; }
fn cuMemcpyHtoD_v2(dst: int64, src: uint8*, bytes: int64) -> int32 { mem_copy((cstring)dst, (cstring)src, (int64)bytes); return 0; }
fn cuMemcpyDtoH_v2(dst: uint8*, src: int64, bytes: int64) -> int32 { mem_copy((cstring)dst, (cstring)src, (int64)bytes); return 0; }
fn cuLaunchKernel(f: int64, gx: uint32, gy: uint32, gz: uint32, bx: uint32, by: uint32, bz: uint32, sharedBytes: uint32, stream: int64, kernelParams: int64*, extra: int64*) -> int32 { return 0; }
fn cuCtxSynchronize() -> int32 { return 0; }

var MOD: int64 = 0;
var FAILS: int32 = 0;

fn getfn(name: cstring) -> int64 {
  var kf: int64 = 0;
  if (cuModuleGetFunction(&kf, MOD, name) != 0) { print(cstr("no kernel ")); println(name); }
  return kf;
}

fn launch3(kf: int64, a: int64, b: int64, c: int64, n: int32) {
  var argv: int64* = (int64*)malloc(32);
  var params: int64* = (int64*)malloc(32);
  argv[0] = a; argv[1] = b; argv[2] = c; argv[3] = (int64)n;
  params[0] = (int64)&argv[0]; params[1] = (int64)&argv[1];
  params[2] = (int64)&argv[2]; params[3] = (int64)&argv[3];
  var threads: int64 = 256; var blocks: int64 = ((int64)n + 255) / 256;
  cuLaunchKernel(kf, (uint32)blocks, 1, 1, (uint32)threads, 1, 1, 0, 0, params, (int64*)0);
  cuCtxSynchronize();
  free((cstring)argv); free((cstring)params);
}
fn launch2(kf: int64, a: int64, c: int64, n: int32) {
  var argv: int64* = (int64*)malloc(24);
  var params: int64* = (int64*)malloc(24);
  argv[0] = a; argv[1] = c; argv[2] = (int64)n;
  params[0] = (int64)&argv[0]; params[1] = (int64)&argv[1]; params[2] = (int64)&argv[2];
  var threads: int64 = 256; var blocks: int64 = ((int64)n + 255) / 256;
  cuLaunchKernel(kf, (uint32)blocks, 1, 1, (uint32)threads, 1, 1, 0, 0, params, (int64*)0);
  cuCtxSynchronize();
  free((cstring)argv); free((cstring)params);
}

fn dabs(x: float64) -> float64 { if (x < 0.0) { return 0.0 - x; } return x; }

fn iref_i64(x: int64, y: int64) -> int64 { return x * y + x / y + x % y + (x << 3) - (x >> 2) + (x & y); }

// Trusted unsigned references: tiny, so they stay on the (correct) MIR backend.
// The k_u32 block computes the SAME math inline in the large fallback main and
// compares; a divergence means the fallback mis-tracked the uint32 as signed.
fn uref_u32(x: uint32, y: uint32) -> uint32 { return x / y + x % y + (x >> 3); }
fn ucast_u32(x: uint32) -> int64 { return (int64)x; }

fn report(name: cstring, ok: int32) {
  if (ok == 1) { print(cstr("  PASS ")); println(name); }
  else { print(cstr("  FAIL ")); println(name); FAILS = FAILS + 1; }
}

fn main() -> int32 {
  var dev: int32 = 0; var ctx: int64 = 0;
  if (cuInit(0) != 0) { println(cstr("cuInit failed")); return 1; }
  cuDeviceGet(&dev, 0); cuCtxCreate_v2(&ctx, 0, dev);
  // (ptx load skipped in the stubbed replica)
  MOD = 1;
  println(cstr("=== differential GPU reliability (emitted PTX vs CPU) ==="));

  var n: int32 = 2048;
  var n64: int64 = (int64)n;

  // ---- k_f64 ----
  {
    var ha: float64* = (float64*)malloc(n64 * 8);
    var hb: float64* = (float64*)malloc(n64 * 8);
    var hc: float64* = (float64*)malloc(n64 * 8);
    var i: int32 = 0;
    while (i < n) { ha[i] = (float64)i * 0.5 - 100.0; hb[i] = (float64)i * 0.25 + 1.0; i = i + 1; }
    var da: int64 = 0; var db: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 8); cuMemAlloc_v2(&db, n64 * 8); cuMemAlloc_v2(&dc, n64 * 8);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 8); cuMemcpyHtoD_v2(db, (uint8*)hb, n64 * 8);
    launch3(getfn(cstr("k_f64")), da, db, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 8);
    var ok: int32 = 1; i = 0;
    // (GPU result unavailable in stub; skip correctness, keep shape)
    report(cstr("k_f64  (f64 mul/add/sub/div)"), ok);
  }

  // ---- k_i64 ----
  {
    var ha: int64* = (int64*)malloc(n64 * 8);
    var hb: int64* = (int64*)malloc(n64 * 8);
    var hc: int64* = (int64*)malloc(n64 * 8);
    var i: int32 = 0;
    while (i < n) { ha[i] = (int64)i * 123 - 456; hb[i] = (int64)(i % 7) + 1; i = i + 1; }
    var da: int64 = 0; var db: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 8); cuMemAlloc_v2(&db, n64 * 8); cuMemAlloc_v2(&dc, n64 * 8);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 8); cuMemcpyHtoD_v2(db, (uint8*)hb, n64 * 8);
    launch3(getfn(cstr("k_i64")), da, db, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 8);
    var ok: int32 = 1; i = 0;
    report(cstr("k_i64  (i64 mul/div/mod/shift/and)"), ok);
  }

  // ---- k_u32 (the signedness test, INLINED) ----
  {
    var ha: uint32* = (uint32*)malloc(n64 * 4);
    var hb: uint32* = (uint32*)malloc(n64 * 4);
    var hc: uint32* = (uint32*)malloc(n64 * 4);
    var i: int32 = 0;
    while (i < n) { ha[i] = (uint32)i * 2654435761; hb[i] = (uint32)(i % 13) + 1; i = i + 1; }
    var da: int64 = 0; var db: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 4); cuMemAlloc_v2(&db, n64 * 4); cuMemAlloc_v2(&dc, n64 * 4);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 4); cuMemcpyHtoD_v2(db, (uint8*)hb, n64 * 4);
    launch3(getfn(cstr("k_u32")), da, db, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 4);
    var ok: int32 = 1; i = 0;
    // INLINED reference math (the shape that mis-tracks uint32 as signed). The
    // values come from a heap load with a runtime-filled buffer so the compiler
    // cannot fold them to clean constants and hide the high-bit sign-extension.
    // `uval` is deliberately NOT named `ref`: a uint32 local sharing a name with
    // the float64 `ref` in the k_f64 block would hit a SEPARATE, backend-
    // independent shadowing bug (same-named locals with different types) and
    // muddy this signedness regression. See the spawned follow-up.
    var x: uint32 = ha[1];   // 1 * 2654435761 = 0x9E3779B1, bit 31 set
    var y: uint32 = hb[1];   // (1 % 13) + 1 = 2
    var uval: uint32 = x / y + x % y + (x >> 3);
    // Compare the inline (fallback) results against the MIR helpers (correct).
    if (uval != uref_u32(x, y)) { ok = 0; }              // chain div/mod/shr
    if ((int64)x != ucast_u32(x)) { ok = 0; }            // local load + (int64) widen
    if ((int64)(x / y) != ucast_u32(x / y)) { ok = 0; }  // cast-chain div
    if ((int64)(x % y) != ucast_u32(x % y)) { ok = 0; }  // cast-chain mod
    if ((int64)(x >> 3) != ucast_u32(x >> 3)) { ok = 0; }// cast-chain shr
    // Direct pointer-deref load (no local) of a high-bit-set uint32 widened to
    // int64 must zero-extend: ha[3] = 3*2654435761 mod 2^32 = 0xDAA9... (bit 31).
    if ((int64)ha[3] != ucast_u32(ha[3])) { ok = 0; }    // uint32* load zero-extend
    report(cstr("k_u32  (UNSIGNED div/rem/shr)"), ok);
  }

  // ---- k_cast_d2i ----
  {
    var ha: float64* = (float64*)malloc(n64 * 8);
    var hc: int32* = (int32*)malloc(n64 * 4);
    var i: int32 = 0;
    while (i < n) { ha[i] = (float64)i * 1.9 - 1000.0; i = i + 1; }
    var da: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 8); cuMemAlloc_v2(&dc, n64 * 4);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 8);
    launch2(getfn(cstr("k_cast_d2i")), da, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 4);
    var ok: int32 = 1; i = 0;
    report(cstr("k_cast_d2i  (f64 -> i32 trunc)"), ok);
  }

  // ---- k_cast_l2f ----
  {
    var ha: int64* = (int64*)malloc(n64 * 8);
    var hc: float32* = (float32*)malloc(n64 * 4);
    var i: int32 = 0;
    while (i < n) { ha[i] = (int64)i * 1000003 - 500; i = i + 1; }
    var da: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 8); cuMemAlloc_v2(&dc, n64 * 4);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 8);
    launch2(getfn(cstr("k_cast_l2f")), da, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 4);
    var ok: int32 = 1; i = 0;
    var ref: float32 = (float32)ha[1];
    report(cstr("k_cast_l2f  (i64 -> f32)"), ok);
  }

  // ---- k_unary ----
  {
    var ha: int32* = (int32*)malloc(n64 * 4);
    var hc: int32* = (int32*)malloc(n64 * 4);
    var i: int32 = 0;
    while (i < n) { ha[i] = i * 37 - 1000; i = i + 1; }
    var da: int64 = 0; var dc: int64 = 0;
    cuMemAlloc_v2(&da, n64 * 4); cuMemAlloc_v2(&dc, n64 * 4);
    cuMemcpyHtoD_v2(da, (uint8*)ha, n64 * 4);
    launch2(getfn(cstr("k_unary")), da, dc, n);
    cuMemcpyDtoH_v2((uint8*)hc, dc, n64 * 4);
    var ok: int32 = 1; i = 0;
    report(cstr("k_unary  (neg + bitnot)"), ok);
  }

  println(cstr("=========================================================="));
  if (FAILS == 0) { println(cstr("ALL HOST UINT32 SIGNEDNESS CHECKS PASS")); }
  else { print(cstr("FAILURES: ")); print_int((int64)FAILS); println(cstr("")); }
  return FAILS;   // exit 0 on success; non-zero == a uint32-as-signed miscompile
}
