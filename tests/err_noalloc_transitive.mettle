// `@noalloc` violated transitively: hot() itself is clean, but it calls
// helper(), which allocates.
struct Node {
    v: int32;
}
@noinline fn helper(v: int32) -> Node* {
    var n: Node* = new Node;
    n->v = v;
    return n;
}
@noalloc fn hot(v: int32) -> int32 {
    var n: Node* = helper(v);
    return n->v;
}
fn main() -> int32 {
    return hot(0);
}
