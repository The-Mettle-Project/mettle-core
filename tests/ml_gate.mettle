fn mix(a: int64, b: int64) -> int64 {
    var p: int64 = a * b + 7;
    var q: int64 = a * b + 7;
    return p + q * 3;
}

fn scrub(buf: int64*, n: int64) -> int64 {
    var i: int64 = 0;
    while (i < n) {
        buf[i] = buf[i] & 255;
        i = i + 1;
    }
    return buf[0] + buf[n - 1];
}

fn signbit(x: int64) -> int64 {
    var neg: int64 = 0;
    if (x < 0) { neg = 1; }
    return neg * 100 + x;
}

fn touch(buf: int64*) -> int64 {
    buf[0] = 41;
    buf[0] = 42;
    return buf[0];
}

fn main() -> int64 {
    var xs: int64[16];
    var i: int64 = 0;
    while (i < 16) { xs[i] = i * 1103515245 + 12345; i = i + 1; }
    var t: int64 = touch(&xs[0]);
    return mix(11, 23) + scrub(&xs[0], 16) + t + signbit(7) + signbit(0 - 9);
}
