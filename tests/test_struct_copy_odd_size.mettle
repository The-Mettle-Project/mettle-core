// Regression: whole-struct assign of an odd-sized struct (size not 1/2/4/8,
// here 3 uint8 fields) must copy EXACTLY size bytes. The fallback backend's
// default 8-byte RAX round-trip wrote past the destination's exact-size slot
// and silently zeroed the adjacent local — the copy SOURCE itself in the
// common `var copy = orig` layout. Found by the v2 differential fuzzer
// (2026-06-09, seed 508): debug was wrong, release (post-SROA) was right.
//
// Exit code 1 = all OK, 0 = miscompiled.

struct S3 {
  f0: uint8;
  f1: uint8;
  f2: uint8;
}

@noinline fn fold(s: S3) -> int64 {
  return ((int64)s.f0 + (int64)s.f1 + (int64)s.f2) & 1099511627775;
}

fn main() -> int32 {
  var sv: S3;
  sv.f0 = (uint8)3; sv.f1 = (uint8)8; sv.f2 = (uint8)7;
  var sc: S3 = sv;                    // must not clobber sv
  sc.f1 = (uint8)208;
  // original intact, copy mutated, by-value args see both correctly
  if ((int64)sv.f0 != 3 || (int64)sv.f1 != 8 || (int64)sv.f2 != 7) { return 0; }
  if (fold(sv) != 18) { return 0; }
  if (fold(sc) != 218) { return 0; }
  if (fold(sc) + fold(sv) != 236) { return 0; }
  return 1;
}
