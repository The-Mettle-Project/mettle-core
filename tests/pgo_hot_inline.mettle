fn keyed_mix(x: int64, k: int64) -> int64 {
    var m: int64 = k;
    m = m ^ (m >> 13); m = m * 31; m = m + 7;
    m = m ^ (m >> 7);  m = m * 37; m = m + 11;
    m = m ^ (m >> 17); m = m * 41; m = m + 13;
    m = m ^ (m >> 5);  m = m * 43; m = m + 17;
    m = m ^ (m >> 11); m = m * 47; m = m + 19;
    m = m ^ (m >> 3);  m = m * 53; m = m + 23;
    m = m ^ (m >> 19); m = m * 59; m = m + 29;
    m = m ^ (m >> 2);  m = m * 61; m = m + 31;
    m = m ^ (m >> 23); m = m * 67; m = m + 37;
    m = m ^ (m >> 29); m = m * 71; m = m + 41;
    m = m ^ (m >> 31); m = m * 73; m = m + 43;
    m = m ^ (m >> 37); m = m * 79; m = m + 47;
    m = m ^ (m >> 41); m = m * 83; m = m + 53;
    m = m ^ (m >> 43); m = m * 89; m = m + 59;
    m = m ^ (m >> 47); m = m * 97; m = m + 61;
    m = m ^ (m >> 53); m = m * 101; m = m + 67;
    m = m ^ (m >> 9);  m = m * 103; m = m + 71;
    m = m ^ (m >> 15); m = m * 107; m = m + 73;
    m = m ^ (m >> 21); m = m * 109; m = m + 79;
    m = m ^ (m >> 27); m = m * 113; m = m + 83;
    m = m ^ (m >> 33); m = m * 127; m = m + 89;
    m = m ^ (m >> 39); m = m * 131; m = m + 97;
    return (x << 1) ^ m;
}

fn main() -> int64 {
    var h: int64 = 1469598103934665603;
    var i: int64 = 0;
    while (i < 100000) {
        h = keyed_mix(h, 987654321);
        i = i + 1;
    }
    return h & 255;
}
