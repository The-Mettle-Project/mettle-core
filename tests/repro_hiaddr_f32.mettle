import "std/io";
import "std/mem";

var WR: uint8* = (uint8*)0;
var SNW: float32* = (float32*)0;

fn load_f32(off: int64, n: int64, dst: float32*) {
  var src: float32* = (float32*)(&WR[off]);
  var i: int64 = 0; while (i < n) { dst[i] = src[i]; i = i + 1; }
}

// big function (forward-like) that calls load_f32 — candidate for inlining
fn forward(off: int64) {
  var a: int64 = 1; var b: int64 = 2; var c: int64 = 3; var d: int64 = 4;
  var e: int64 = 5; var f: int64 = 6; var g: int64 = 7; var h: int64 = 8;
  var l: int64 = 0;
  while (l < 1) {
    load_f32(off, 3840, SNW);
    print(cstr("[forward] SNW[0..3]*1e4= ")); var z: int64 = 0;
    while (z < 4) { print_int((int64)(SNW[z]*10000.0)); print(cstr(" ")); z = z + 1; }
    println(cstr(""));
    l = l + 1;
  }
  print_int(a+b+c+d+e+f+g+h); println(cstr(""));
}

fn main() -> int32 {
  WR = malloc(6000000000);
  if (WR == 0) { println(cstr("malloc failed")); return 1; }
  SNW = (float32*)malloc(4*4096);
  var off: int64 = 830194688;
  var p: float32* = (float32*)(&WR[off]);
  p[0] = 17.875; p[1] = 30.375; p[2] = 0.0; p[3] = 16.125;
  print(cstr("[main] WR=")); print_int((int64)WR); println(cstr(""));

  load_f32(off, 3840, SNW);
  print(cstr("[main] load_f32 SNW[0..3]*1e4= ")); var z: int64 = 0;
  while (z < 4) { print_int((int64)(SNW[z]*10000.0)); print(cstr(" ")); z = z + 1; }
  println(cstr(""));

  forward(off);
  return 0;
}
