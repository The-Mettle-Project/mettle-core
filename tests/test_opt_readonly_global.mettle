import "std/io";

var STRIDE: int64 = 12;
var COUNTER: int64 = 100;
var NEG: int32 = -7;

fn bump() {
  COUNTER = COUNTER + 1;
}

fn scaled(i: int64) -> int64 {
  return i * STRIDE;
}

fn main() -> int32 {
  if (scaled(5) != 60) {
    println("STRIDE fold FAILED");
    return 2;
  }
  if ((int64)NEG * 3 != -21) {
    println("NEG fold FAILED");
    return 2;
  }

  bump();
  bump();
  if (COUNTER != 102) {
    print("COUNTER wrongly folded: ");
    println_int(COUNTER);
    return 2;
  }

  println("readonly_global OK");
  return 0;
}
