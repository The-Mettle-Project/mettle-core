import "std/io";

fn then_defer() { puts(cstr("THEN_DEFER\n")); }
fn else_defer() { puts(cstr("ELSE_DEFER\n")); }
fn then_body() { puts(cstr("THEN_BODY\n")); }
fn else_body() { puts(cstr("ELSE_BODY\n")); }
fn after_if() { puts(cstr("AFTER_IF\n")); }

fn main() -> int32 {
  if (1) {
    defer then_defer();
    then_body();
  } else {
    defer else_defer();
    else_body();
  }

  after_if();
  return 0;
}
