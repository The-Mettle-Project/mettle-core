export struct Pair {
  left: int32;
  right: int32;
}

export enum Magic {
  FortyTwo = 42,
  Seven = 7
}

export var seed: int32 = 40;

fn private_bonus() -> int32 {
  return 2;
}

export fn make_pair(left: int32, right: int32) -> Pair* {
  var pair: Pair* = new Pair;
  pair->left = left;
  pair->right = right;
  return pair;
}

export fn total(pair: Pair*) -> int32 {
  return pair->left + pair->right;
}

export fn answer() -> int32 {
  return seed + private_bonus();
}
