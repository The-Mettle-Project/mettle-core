// Coverage: the natural cast-free int reduction `s += a[i]` (int32 array into an
// int64 accumulator) now vectorizes -- pointer-induction leaves reductions
// indexed, and sum_i32 admits the implicit int32->int64 widen. Verify the
// vectorized result equals the closed form, with negative inputs stressing the
// signed widening. Returns 0 on success.
fn isum(a: int32*, n: int32) -> int64 {
  var s: int64 = 0;
  for i in 0..n { s = s + a[i]; }
  return s;
}
fn main() -> int32 {
  var n: int32 = 4096;
  var a: int32[4096];
  for i in 0..n { a[i] = i * 7 - 1000000; }
  var got: int64 = isum(&a[0], n);
  var ref: int64 = (int64)7 * (int64)n * (int64)(n - 1) / 2 - (int64)1000000 * (int64)n;
  if (got == ref) { return 0; }
  return 1;
}
