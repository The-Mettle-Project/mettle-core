kernel bad_sparse_metadata(a: uint16*, b: uint16*, c: float32*,
                           d: float32*, metadata: uint32*) {
  tensor_mma(a, b, c, d,
             shape: m16n16k16,
             input_type: f16,
             output_type: f32,
             sparsity: structured_2_to_4,
             metadata: metadata);
}
