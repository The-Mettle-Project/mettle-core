// Signed narrow canonical-home semantics: signed sub-64-bit arithmetic wraps
// to the destination width when stored into a typed home, and the home must be
// sign-extended before later width-sensitive operations like division/shift.
// Exit code: bitmask of failed checks (0 = all pass).

extern fn exit2(code: int32) -> int32 = "exit";

var G: int32 = 0;

fn sDiv(x: int32) -> int32 {
  var t: int32 = x + 9;
  var q: int32 = t / 7;
  return q;
}

fn sShr(x: int32) -> int32 {
  var t: int32 = x + 9;
  var q: int32 = t >> 1;
  return q;
}

fn wideAssignDiv(x: int32) -> int32 {
  var wide: int64 = (int64)x + 9;
  var t: int32 = wide;
  var q: int32 = t / 7;
  return q;
}

fn gDiv(x: int32) -> int32 {
  G = x;
  G = G + 9;
  return G / 7;
}

fn s16Div(x: int16) -> int32 {
  var t: int16 = x + 5;
  var q: int16 = t / 3;
  return q;
}

fn s8Div(x: int8) -> int32 {
  var t: int8 = x + 2;
  var q: int8 = t / 3;
  return q;
}

fn main() -> int32 {
  var fail: int32 = 0;
  if (sDiv(2147483647) != (0 - 306783377)) { fail = fail | 1; }
  if ((int64)sDiv(2147483647) != (0 - 306783377)) { fail = fail | 2; }
  if (sShr(2147483647) != (0 - 1073741820)) { fail = fail | 4; }
  if (wideAssignDiv(2147483647) != (0 - 306783377)) { fail = fail | 8; }
  if (gDiv(2147483647) != (0 - 306783377)) { fail = fail | 16; }
  if (s16Div(32767) != (0 - 10921)) { fail = fail | 32; }
  if (s8Div(127) != (0 - 42)) { fail = fail | 64; }
  exit2(fail);
  return 0;
}
