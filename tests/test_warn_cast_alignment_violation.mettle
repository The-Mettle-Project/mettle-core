extern fn malloc(size: int32) -> uint8* = "malloc";
extern fn free(ptr: uint8*) = "free";

fn main() -> int32 {
  var p: uint8* = malloc(8);
  if (p == 0) {
    return 1;
  }

  var q: int64* = (int64*)(p + 1);
  if (q == 0) {
    free(p);
    return 2;
  }

  free(p);
  return 0;
}
