kernel tensor_wrong_packing(a: uint16*, b: uint16*,
                            c: float32*, d: float32*) {
  tensor_mma(a, b, c, d,
             shape: m16n16k16,
             input_type: f16, output_type: f32,
             a_packing: dense_subbyte,
             a_layout: row, b_layout: col,
             c_layout: row, d_layout: row);
}
