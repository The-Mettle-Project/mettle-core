// Regression: the inline SIMD fill kernel (IR_OP_SIMD_FILL) now runs through the
// MIR register-allocating backend instead of bailing the whole function to
// spill-everything codegen. Covers the supported subset:
//   - mode 1 (begin->end byte walk), the ptr-induction form of `a[i] = c`,
//   - mode 0 with a runtime invariant offset folded as base + offset*size,
//   - the live-induction-variable write-back (iv = max(count, 0)),
//   - a non-leaf function (a call present) so xmm/arg-reg handling is exercised.
// Exit code 1 = every result correct, 0 = some path miscompiled. Built debug,
// release, and *_fallback (METTLE_MIR=0) so MIR and the legacy backend agree.
import "std/io";
import "std/mem";

var gbuf: int64* = (int64*)0;

@noinline fn touch(x: int64) -> int64 { return x + 1; }

@noinline fn zero_then_sum(a: int32*, n: int64) -> int64 {
  var i: int64 = 0;
  while (i < n) { a[i] = 0; i = i + 1; }     // mode 1 fill
  var s: int64 = 0;
  var j: int64 = 0;
  while (j < n) { s = s + (int64)a[j]; j = j + 1; }
  return s;                                   // 0
}

@noinline fn offset_fill_reuse(off: int64, n: int64) -> int64 {
  var i: int64 = 0;
  while (i < n) { gbuf[off + i] = 0; i = i + 1; }   // mode 0, runtime offset, live i
  var s: int64 = 0;
  while (i > 0) { i = i - 1; s = s + gbuf[off + i]; } // reuse i: must start at n
  return s + i;                                       // i must be 0; s = 0
}

@noinline fn seedg(n: int64) {
  var i: int64 = 0;
  while (i < n) { gbuf[i] = 5; i = i + 1; }
}

fn main() -> int32 {
  var ok: int32 = 1;
  var t: int64 = touch(1);                 // force a call (non-leaf)
  if (t != 2) { ok = 0; }

  var buf: int32[200];
  if (zero_then_sum((int32*)((int64)(&buf[0])), 200) != 0) { ok = 0; }

  gbuf = (int64*)((int64)malloc(64 * 8));
  seedg(64);
  if (offset_fill_reuse(8, 16) != 0) { ok = 0; }   // zeros gbuf[8..24)
  var sum: int64 = 0;
  var k: int64 = 0;
  while (k < 64) { sum = sum + gbuf[k]; k = k + 1; }
  if (sum != 240) { ok = 0; }              // 64*5 - 16*5 = 240

  if (ok == 1) { return 1; }
  return 0;
}
