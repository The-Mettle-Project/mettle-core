import "std/io";

// @pure + @noinline: the call survives inlining (noinline) and is hoisted out
// of the loop by pure-call LICM (pure). sq(7) = 49.
@pure @noinline fn sq(x: int32) -> int32 {
  return x * x;
}

// @noinline leaf so the calls below stay as calls.
@noinline fn leaf() -> int32 {
  return 1;
}

// 3 internal calls exceeds the inliner's call-count heuristic (>2), so this is
// normally NOT inlined. @inline forces it past that gate.
@inline fn many_calls() -> int32 {
  return leaf() + leaf() + leaf();
}

// @simd! on a function applies the vectorization contract to every counted loop
// in the body. This sum loop must vectorize (sum_i32) or compilation fails.
@simd! fn sum_arr(a: int32*, n: int64) -> int64 {
  var s: int64 = 0;
  var i: int64 = 0;
  while (i < n) {
    s = s + (int64)a[i];
    i = i + 1;
  }
  return s;
}

fn pure_sum() -> int32 {
  var total: int32 = 0;
  var k: int32 = 7;
  var i: int32 = 0;
  while (i < 1000) {
    total = total + sq(k);
    i = i + 1;
  }
  return total;
}

// Pure call with a POINTER argument. The pointer is loop-invariant and the loop
// body never stores, so reading through it is stable across iterations and the
// call may be hoisted. sum3(&buf) = 1+2+3 = 6, over 10 iterations = 60.
@pure @noinline fn sum3(p: int32*) -> int32 {
  return p[0] + p[1] + p[2];
}

fn pure_ptr_sum() -> int32 {
  var buf: int32[3];
  buf[0] = 1; buf[1] = 2; buf[2] = 3;
  var p: int32* = &buf[0];
  var total: int32 = 0;
  var i: int32 = 0;
  while (i < 10) {
    total = total + sum3(p);
    i = i + 1;
  }
  return total;
}

// SOUNDNESS GUARD: the loop body WRITES the memory `first` reads, so the call
// must NOT be hoisted. If the no-store-in-body rule failed and it were hoisted,
// the result would be wrong. Correct (not hoisted): 0+1+2+3+4 = 10.
@pure @noinline fn first(p: int32*) -> int32 {
  return p[0];
}

fn aliased_no_hoist() -> int32 {
  var buf: int32[1];
  buf[0] = 0;
  var sum: int32 = 0;
  var i: int32 = 0;
  while (i < 5) {
    buf[0] = i;
    sum = sum + first(&buf[0]);
    i = i + 1;
  }
  return sum;
}

// SOUNDNESS GUARD 2: a @pure function that READS a global, hoisted out of a
// loop whose body MUTATES that global, would read a stale value. A global write
// lowers to an ASSIGN (not a STORE), so the body's no-store rule alone misses
// it; the LICM must additionally refuse to hoist when the body writes a global.
// Correct (not hoisted): g_read sees 1,2,3,4,5 ->
//   (10+1)+(10+2)+(10+3)+(10+4)+(10+5) = 50 + 15 = 65.
var g_read: int32 = 0;

@pure @noinline fn read_plus_global(x: int32) -> int32 {
  return x + g_read;
}

fn global_read_no_hoist() -> int32 {
  g_read = 0;
  var total: int32 = 0;
  var i: int32 = 0;
  while (i < 5) {
    g_read = g_read + 1;
    total = total + read_plus_global(10);
    i = i + 1;
  }
  return total;
}

// SOUNDNESS GUARD 3: a function mislabeled @pure that MUTATES a global is not
// observationally pure. Hoisting its call out of a loop would change how many
// times the side effect runs, so the LICM inspects the callee's body and
// declines. Correct (called 5x): g_writes == 5.
var g_writes: int32 = 0;

@pure @noinline fn bump_global(x: int32) -> int32 {
  g_writes = g_writes + 1;
  return x;
}

fn global_write_no_hoist() -> int32 {
  g_writes = 0;
  var s: int32 = 0;
  var i: int32 = 0;
  while (i < 5) {
    s = s + bump_global(1);
    i = i + 1;
  }
  return g_writes;
}

fn main() -> int32 {
  var ps: int32 = pure_sum();
  var mc: int32 = many_calls();
  var pps: int32 = pure_ptr_sum();
  var anh: int32 = aliased_no_hoist();
  var grn: int32 = global_read_no_hoist();
  var gwn: int32 = global_write_no_hoist();

  var buf: int32[8];
  var j: int32 = 0;
  while (j < 8) { buf[j] = j + 1; j = j + 1; }
  var total: int64 = sum_arr(&buf[0], 8);

  print(cstr("ps=")); print_int((int64)ps); println(cstr(""));
  print(cstr("mc=")); print_int((int64)mc); println(cstr(""));
  print(cstr("pps=")); print_int((int64)pps); println(cstr(""));
  print(cstr("anh=")); print_int((int64)anh); println(cstr(""));
  print(cstr("grn=")); print_int((int64)grn); println(cstr(""));
  print(cstr("gwn=")); print_int((int64)gwn); println(cstr(""));
  print(cstr("sum=")); print_int(total); println(cstr(""));

  if (ps == 49000 && mc == 3 && pps == 60 && anh == 10 && grn == 65 &&
      gwn == 5 && total == 36) {
    println(cstr("DECORATORS OK"));
    return 0;
  }
  println(cstr("DECORATORS FAIL"));
  return 1;
}
