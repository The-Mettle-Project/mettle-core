// `@inline!` is a contract: every call to `fact` must inline. A recursive
// function can never have ALL its calls inlined away, so this must fail.
@inline! fn fact(n: int32) -> int32 {
    if (n <= 1) { return 1; }
    return n * fact(n - 1);
}
fn main() -> int32 {
    return fact(5) - 120;
}
