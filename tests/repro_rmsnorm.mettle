import "std/io";
import "std/mem";

extern fn sqrtf(x: float32) -> float32 = "sqrtf";

var WR: uint8* = (uint8*)0;
var SNW: float32* = (float32*)0;
var SXN: float32* = (float32*)0;
var SX: float32* = (float32*)0;

fn rmsnorm(x: float32*, w: float32*, y: float32*, n: int64) {
  var ss: float32 = 0.0; var i: int64 = 0;
  while (i < n) { ss = ss + x[i] * x[i]; i = i + 1; }
  var r: float32 = 1.0 / sqrtf(ss / (float32)n + 0.000001);
  i = 0; while (i < n) { y[i] = x[i] * r * (1.0 + w[i]); i = i + 1; }
}

fn load_f32(off: int64, n: int64, dst: float32*) {
  var src: float32* = (float32*)(&WR[off]);
  var i: int64 = 0; while (i < n) { dst[i] = src[i]; i = i + 1; }
}

fn forward(off: int64) {
  var a: int64 = 1; var b: int64 = 2; var c: int64 = 3; var d: int64 = 4;
  var l: int64 = 0;
  while (l < 1) {
    load_f32(off, 3840, SNW);
    print(cstr("[fwd] snw after load[0..3]*1e4: ")); var zz: int64 = 0;
    while (zz < 4) { print_int((int64)(SNW[zz]*10000.0)); print(cstr(" ")); zz = zz + 1; }
    println(cstr(""));
    rmsnorm(SX, SNW, SXN, 3840);
    print(cstr("[fwd] snw after rmsnorm[0..3]*1e4: ")); zz = 0;
    while (zz < 4) { print_int((int64)(SNW[zz]*10000.0)); print(cstr(" ")); zz = zz + 1; }
    println(cstr(""));
    l = l + 1;
  }
  print_int(a+b+c+d); println(cstr(""));
}

fn main() -> int32 {
  WR = malloc(6000000000);
  if (WR == 0) { println(cstr("malloc failed")); return 1; }
  SNW = (float32*)malloc(4*4096);
  SXN = (float32*)malloc(4*4096);
  SX = (float32*)malloc(4*4096);
  var i: int64 = 0; while (i < 3840) { SX[i] = 0.5; i = i + 1; }
  var off: int64 = 830194688;
  var p: float32* = (float32*)(&WR[off]);
  p[0] = 17.875; p[1] = 30.375; p[2] = 0.0; p[3] = 16.125;
  i = 4; while (i < 3840) { p[i] = 1.0; i = i + 1; }
  forward(off);
  return 0;
}
