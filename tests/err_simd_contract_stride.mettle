// @simd! on a non-unit-stride loop (a[i*2]): not vectorizable, but the body has
// NO user control flow -- only a compiler-injected null-check branch on `a`.
// Regression pin: at -O that null-check branch must NOT be counted as control
// flow (it was, before the runtime-check-label exclusion). The reason must be
// the generic "shape is not vectorizable", not "control flow".
fn strided(a: int32*, n: int32) -> int64 {
  var s: int64 = 0;
  @simd! for i in 0..n { s = s + (int64)a[i * 2]; }
  return s;
}
fn main() -> int32 { return 0; }
