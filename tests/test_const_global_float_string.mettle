// Global consts of non-integer type: float and string. The float const drives a
// deterministic exit code (1.5 * 28 = 42) and the string const is loaded into a
// typed local so codegen must emit and link it as a global. Returns 42.
const RATE = 1.5;
const LABEL = "ok";
fn main() -> int32 {
  var s: string = LABEL;
  return (int32)(RATE * 28.0);
}
