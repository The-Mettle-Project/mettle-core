// Exact transposed whole-matrix regions. PTX may normalize the stored layout
// into a backend-local native view; no frontend or shared-IR transpose occurs.

kernel tensor_matmul_f16_transpose_a(
    a: uint16*, b: uint16*, c: float32*, d: float32*,
    row_origin: uint32, column_origin: uint32,
    problem_m: uint32, problem_n: uint32, problem_k: uint32,
    lda: uint32, ldb: uint32, ldc: uint32, ldd: uint32) {
  tensor_matmul(
      a, b, c, d, row_origin, column_origin,
      problem_m, problem_n, problem_k,
      shape: m16n16k16, input_type: f16, output_type: f32,
      a_layout: row, b_layout: col, transpose_a: true,
      lda: lda, ldb: ldb, ldc: ldc, ldd: ldd);
}

kernel tensor_matmul_f16_transpose_b(
    a: uint16*, b: uint16*, c: float32*, d: float32*,
    row_origin: uint32, column_origin: uint32,
    problem_m: uint32, problem_n: uint32, problem_k: uint32) {
  tensor_matmul(
      a, b, c, d, row_origin, column_origin,
      problem_m, problem_n, problem_k,
      shape: m16n16k16, input_type: f16, output_type: f32,
      a_layout: col, b_layout: col, transpose_b: true,
      lda: 67, ldb: 71, ldc: 73, ldd: 79);
}

kernel tensor_matmul_f64_transpose_ab(
    a: float64*, b: float64*, c: float64*, d: float64*,
    row_origin: uint32, column_origin: uint32,
    problem_m: uint32, problem_n: uint32, problem_k: uint32) {
  tensor_matmul(
      a, b, c, d, row_origin, column_origin,
      problem_m, problem_n, problem_k,
      shape: m8n8k4, input_type: f64, output_type: f64,
      a_layout: col, b_layout: row,
      transpose_a: true, transpose_b: true,
      lda: 67, ldb: 71, ldc: 73, ldd: 79);
}
