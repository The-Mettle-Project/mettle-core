import "std/io";

fn block_err() { puts(cstr("BLOCK_ERR\n")); }
fn block_ok() { puts(cstr("BLOCK_OK\n")); }
fn outer_err() { puts(cstr("OUTER_ERR\n")); }
fn outer_ok() { puts(cstr("OUTER_OK\n")); }

fn main() -> int32 {
  errdefer outer_err();
  defer outer_ok();

  {
    errdefer block_err();
    defer block_ok();
  }

  return 0;
}
