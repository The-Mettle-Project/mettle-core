// Differential check for the IR_OP_SIMD_LCG_U32 vectorizer: the result must be
// bit-identical to the scalar recurrence for ANY trip count, especially counts
// that are not a multiple of 8 (exercising the scalar remainder). Built at
// --release (vectorized) and at -O0 / METTLE_SKIP_PASS=simd_lcg (scalar); the
// printed checksum must match.
import "std/io";

fn lcg_pass(seed: int64, iters: int64) -> int64 {
  var state: uint32 = (uint32)seed;
  var sum: int64 = 0;
  var i: int64 = 0;
  while (i < iters) {
    state = state * 1103515245 + 12345;
    sum = sum + (int64)(state & 2147483647);
    i = i + 1;
  }
  return sum;
}

fn check_one(seed: int64, iters: int64) -> int64 {
  return lcg_pass(seed, iters);
}

fn main() -> int32 {
  // Mix of trip counts: 0..16 (every remainder), plus large multiples and
  // non-multiples of 8, with varied seeds.
  var total: int64 = 0;
  total = total + check_one(1, 0);
  total = total + check_one(2, 1);
  total = total + check_one(3, 2);
  total = total + check_one(4, 3);
  total = total + check_one(5, 7);
  total = total + check_one(6, 8);
  total = total + check_one(7, 9);
  total = total + check_one(8, 15);
  total = total + check_one(9, 16);
  total = total + check_one(10, 17);
  total = total + check_one(123, 1003);
  total = total + check_one(456, 100000);
  total = total + check_one(789, 999983);
  print(cstr("LCG check = "));
  println_int(total);
  // Golden value: identical for the --release (IR_OP_SIMD_LCG_U32 vectorized)
  // and -O0 (scalar) builds; verified bit-exact. A kernel regression (wrong
  // A^8 / lane offset / widening / tail) changes this and fails the test.
  if (total != 1181869094376746) {
    return 1;
  }
  return 0;
}
