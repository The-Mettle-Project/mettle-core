// Correct ownership code that the borrow checker must NOT warn about. This is
// the zero-false-positive guard: every function here is sound, so any memory
// diagnostic is a regression. Covers the tricky shapes that have bitten the
// alias analysis -- the safe realloc idiom, disjoint frees, and re-pointed
// aliases -- all inferred, no annotations.
import "std/io";
import "std/mem";

// The standard safe realloc idiom: the result is checked, then assigned back.
fn clean_safe_realloc() -> int32 {
    var buf: cstring = malloc(8);
    buf[0] = 1;
    var tmp: cstring = realloc(buf, 16);
    if (tmp != 0) {
        buf = tmp;
    }
    buf[0] = 2;
    var r: int32 = (int32)buf[0];
    free(buf);
    return r;
}

// An alias to a different block than the one freed.
fn clean_disjoint_free() -> int32 {
    var a: cstring = malloc(8);
    var b: cstring = malloc(8);
    a[0] = 1;
    var q: cstring = a;
    free(b);
    var r: int32 = (int32)q[0];
    free(a);
    return r;
}

// Alias re-pointed to its own block before the original is freed.
fn clean_repoint() -> int32 {
    var p: cstring = malloc(8);
    var q: cstring = p;
    q = malloc(8);
    q[0] = 5;
    free(p);
    var r: int32 = (int32)q[0];
    free(q);
    return r;
}

// Read the alias before freeing the block it shares.
fn clean_read_first() -> int32 {
    var owned: cstring = malloc(8);
    var peek: cstring = owned;
    var v: int32 = (int32)peek[0];
    free(owned);
    return v;
}

fn main() -> int32 {
    return clean_safe_realloc() + clean_disjoint_free() + clean_repoint() + clean_read_first();
}
