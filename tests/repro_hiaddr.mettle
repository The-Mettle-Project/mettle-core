import "std/io";
import "std/mem";

var G: uint8* = (uint8*)0;

fn rdf(off: int64, n: int64, dst: int32*) {
  var s: int32* = (int32*)(&G[off]);
  var i: int64 = 0; while (i < n) { dst[i] = s[i]; i = i + 1; }
}

// a big function with lots of locals to create register pressure / inlining
fn work(off: int64, dst: int32*) {
  var a: int64 = 1; var b: int64 = 2; var c: int64 = 3; var d: int64 = 4;
  var e: int64 = 5; var f: int64 = 6; var g: int64 = 7; var h: int64 = 8;
  rdf(off, 3840, dst);
  print(cstr("[work] dst[0..3]= ")); var z: int64 = 0;
  while (z < 4) { print_int((int64)dst[z]); print(cstr(" ")); z = z + 1; }
  println(cstr(""));
  // keep locals live
  print_int(a+b+c+d+e+f+g+h);
  println(cstr(""));
}

fn main() -> int32 {
  var sz: int64 = 6000000000;
  G = malloc(sz);
  if (G == 0) { println(cstr("malloc failed")); return 1; }
  var off: int64 = 830194688;  // < 4GB offset, but base > 4GB so addr > 4GB
  // write sentinels
  var p: int32* = (int32*)(&G[off]);
  p[0] = 111; p[1] = 222; p[2] = 333; p[3] = 444;
  print(cstr("[main] G=")); print_int((int64)G); print(cstr(" addr=")); print_int((int64)p); println(cstr(""));
  // inline read-back
  var pr: int32* = (int32*)(&G[off]);
  print(cstr("[main] inline readback[0..3]= ")); var zz: int64 = 0;
  while (zz < 4) { print_int((int64)pr[zz]); print(cstr(" ")); zz = zz + 1; }
  println(cstr(""));

  var d1: int32* = (int32*)malloc(4*4096);
  rdf(off, 3840, d1);
  print(cstr("[main] rdf dst[0..3]= ")); var z: int64 = 0;
  while (z < 4) { print_int((int64)d1[z]); print(cstr(" ")); z = z + 1; }
  println(cstr(""));

  var d2: int32* = (int32*)malloc(4*4096);
  work(off, d2);
  return 0;
}
