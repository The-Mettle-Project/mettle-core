kernel bad_tensor_matmul_tf32_tail(
    a: float32*, b: float32*, c: float32*, d: float32*,
    row: uint32, column: uint32, m: uint32, n: uint32, k: uint32) {
  tensor_matmul(
      a, b, c, d, row, column, m, n, k,
      shape: m16n16k8, input_type: tf32, output_type: f32,
      lda: 64, ldb: 64, ldc: 64, ldd: 64);
}
