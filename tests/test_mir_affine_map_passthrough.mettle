// Regression: the float32 affine-map SIMD kernel (IR_OP_SIMD_AFFINE_MAP_F32 --
// the `dst[i] = a*src[i] + b*dst[i] + c` / float-copy / saxpy class) now runs
// through the MIR register-allocating backend (compile-time coefficients baked
// into the kernel's broadcasts) instead of bailing the whole function to
// spill-everything codegen. This is what makes the qwen3 engine's load_f32 and
// process_token register-allocated. Exit code 1 = correct, 0 = miscompiled.
// Built debug + release + *_fallback so MIR and the legacy backend agree.
import "std/io";

@noinline fn touch(x: int64) -> int64 { return x + 1; }

@noinline fn fcopy(dst: float32*, src: float32*, n: int64) {
  var i: int64 = 0; while (i < n) { dst[i] = src[i]; i = i + 1; }       // a=1,b=0,c=0
}
@noinline fn fadd_into(dst: float32*, src: float32*, n: int64) {
  var i: int64 = 0; while (i < n) { dst[i] = src[i] + dst[i]; i = i + 1; } // a=1,b=1,c=0
}
@noinline fn faffine(dst: float32*, src: float32*, n: int64) {
  var i: int64 = 0; while (i < n) { dst[i] = src[i] * 2.0 + 3.0; i = i + 1; } // a=2,b=0,c=3
}

fn ssum(a: float32*, n: int64) -> int64 {
  var s: float32 = 0.0; var i: int64 = 0;
  while (i < n) { s = s + a[i]; i = i + 1; }
  return (int64)s;
}

fn main() -> int32 {
  var ok: int32 = 1;
  if (touch(1) != 2) { ok = 0; }      // force a call (non-leaf)

  var a: float32[50]; var b: float32[50];
  var i: int64 = 0; while (i < 50) { a[i] = (float32)i; b[i] = 100.0; i = i + 1; }
  var pa: float32* = (float32*)((int64)(&a[0]));
  var pb: float32* = (float32*)((int64)(&b[0]));

  fcopy(pb, pa, 50);                              // b[i] = i
  if (ssum(pb, 50) != 1225) { ok = 0; }          // sum 0..49 = 1225

  fadd_into(pb, pa, 50);                          // b[i] = i + i = 2i
  if (ssum(pb, 50) != 2450) { ok = 0; }          // 2*1225

  faffine(pb, pa, 50);                            // b[i] = i*2 + 3
  if (ssum(pb, 50) != 2600) { ok = 0; }          // 2*1225 + 3*50 = 2600

  if (ok == 1) { return 1; }
  return 0;
}
