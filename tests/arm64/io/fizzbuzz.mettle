import "std/io";
fn main() -> int32 {
  var i: int64 = 1;
  while (i <= 15) {
    if (i % 15 == 0) {
      println(cstr("FizzBuzz"));
    } else {
      if (i % 3 == 0) {
        println(cstr("Fizz"));
      } else {
        if (i % 5 == 0) {
          println(cstr("Buzz"));
        } else {
          println_int(i);
        }
      }
    }
    i = i + 1;
  }
  return 0;
}
