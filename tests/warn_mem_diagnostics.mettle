// Warning-class memory diagnostics: each function below contains one bug the
// compiler reports without failing the build.
import "std/io";
import "std/mem";

var STASH: int32* = 0;

// M0102 double free, then M0101 use-after-free.
fn double_free_then_use() -> int32 {
    var p: cstring = malloc(64);
    free(p);
    free(p);
    return (int32)p[0];
}

// M0104: a stack address stored in a global outlives the frame.
fn stash_stack_address() {
    var slot: int32[2];
    slot[0] = 1;
    STASH = (int32*)&slot[0];
}

// M0107: the allocation neither escapes nor gets freed.
fn leak_sixty_four() -> int32 {
    var scratch: cstring = malloc(64);
    scratch[0] = 9;
    return (int32)scratch[0];
}

// Definite null dereference: assigned null on the spine, dereferenced with
// no reassignment or guard between.
fn null_deref() -> int32 {
    var p: int32* = 0;
    return p[0];
}

// Shift wider than the value: x86 masks the count, so this is x, not 0.
fn over_shift(x: int32) -> int32 {
    return x << 32;
}

// A small constant cast to a pointer can never be valid memory.
fn wild_pointer() -> int32 {
    var p: int32* = (int32*)64;
    return p[0];
}

// Clean control group: conditional frees and defers must stay silent.
fn clean(n: int32) -> int32 {
    var p: cstring = malloc(64);
    defer free(p);
    if (n > 0) {
        p[0] = (uint8)n;
    }
    return (int32)p[0];
}

// Clean: the guard mentions p, so definite-null knowledge ends there.
fn clean_guarded_null(n: int32) -> int32 {
    var p: int32* = 0;
    if (n > 0) {
        p = (int32*)malloc(8);
    }
    if (p != 0) {
        return p[0];
    }
    return 0;
}

// Clean: `<` against the length is the correct bound.
fn clean_loop(values: int32*) -> int32 {
    var a: int32[8];
    var i: int32 = 0;
    while (i < 8) {
        a[i] = values[i];
        i = i + 1;
    }
    return a[7];
}

// Clean: a break can leave before the final iteration, so no claim is made.
fn clean_loop_with_break(limit: int32) -> int32 {
    var a: int32[8];
    var i: int32 = 0;
    while (i <= 8) {
        if (i >= limit) {
            break;
        }
        a[i] = i;
        i = i + 1;
    }
    return a[0];
}

fn main() -> int32 {
    var values: int32[8];
    var k: int32 = 0;
    while (k < 8) { values[k] = k; k = k + 1; }
    var total: int32 = double_free_then_use() + leak_sixty_four() + clean(3) + null_deref() + over_shift(1) + wild_pointer() + clean_guarded_null(0) + clean_loop(&values[0]) + clean_loop_with_break(4);
    stash_stack_address();
    println_int(total);
    return 0;
}
