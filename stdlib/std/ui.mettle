}

export fn ui_checkbox_is_checked(control: int64) -> int32 {
  if ((int32)Ui_SendMessageA(control, UI_BM_GETCHECK(), 0, 0) == UI_BST_CHECKED()) {
    return 1;
  }
  return 0;
}

export fn ui_checkbox_set_checked(control: int64, checked: int32) {
  if (checked != 0) {
    Ui_SendMessageA(control, UI_BM_SETCHECK(), UI_BST_CHECKED(), 0);
    return;
  }
  Ui_SendMessageA(control, UI_BM_SETCHECK(), UI_BST_UNCHECKED(), 0);
}

