// Module state.
var UI_CLASS_NAME: string = "MettleUiWindow";
var ui_class_registered: int32 = 0;
var ui_app_instance: int64 = 0;

// General helpers.
export fn ui_rgb(r: uint32, g: uint32, b: uint32) -> uint32 {
  return r | (g << 8) | (b << 16);
}

export fn ui_color_r(color: uint32) -> uint32 {
  return color & 0xFF;
}

export fn ui_color_g(color: uint32) -> uint32 {
  return (color >> 8) & 0xFF;
}

export fn ui_color_b(color: uint32) -> uint32 {
  return (color >> 16) & 0xFF;
}

export fn ui_lo_word(value: int64) -> uint32 {
  return (uint32)value & 0xFFFF;
}

export fn ui_hi_word(value: int64) -> uint32 {
  return ((uint32)value >> 16) & 0xFFFF;
}

export fn ui_make_point(x: int32, y: int32) -> UiPoint {
  var point: UiPoint;
  point.x = x;
  point.y = y;
  return point;
}

export fn ui_make_size(width: int32, height: int32) -> UiSize {
  var size: UiSize;
  size.width = width;
  size.height = height;
  return size;
}

export fn ui_make_insets(all: int32) -> UiInsets {
  var insets: UiInsets;
  insets.left = all;
  insets.top = all;
  insets.right = all;
  insets.bottom = all;
  return insets;
}

export fn ui_make_insets_xy(x: int32, y: int32) -> UiInsets {
  var insets: UiInsets;
  insets.left = x;
  insets.right = x;
  insets.top = y;
  insets.bottom = y;
  return insets;
}

export fn ui_make_rect(left: int32, top: int32, right: int32, bottom: int32) -> UiRect {
  var rect: UiRect;
  rect.left = left;
  rect.top = top;
  rect.right = right;
  rect.bottom = bottom;
  return rect;
}

export fn ui_rect_xywh(x: int32, y: int32, width: int32, height: int32) -> UiRect {
  return ui_make_rect(x, y, x + width, y + height);
}

export fn ui_rect_width(rect: UiRect) -> int32 {
  return rect.right - rect.left;
}

export fn ui_rect_height(rect: UiRect) -> int32 {
  return rect.bottom - rect.top;
}

export fn ui_rect_is_empty(rect: UiRect) -> int32 {
  if (ui_rect_width(rect) <= 0) { return 1; }
  if (ui_rect_height(rect) <= 0) { return 1; }
  return 0;
}

export fn ui_rect_inset(rect: UiRect, insets: UiInsets) -> UiRect {
  return ui_make_rect(rect.left + insets.left, rect.top + insets.top, rect.right - insets.right, rect.bottom - insets.bottom);
}

export fn ui_rect_offset(rect: UiRect, dx: int32, dy: int32) -> UiRect {
  return ui_make_rect(rect.left + dx, rect.top + dy, rect.right + dx, rect.bottom + dy);
}

export fn ui_rect_contains(rect: UiRect, x: int32, y: int32) -> int32 {
  if (x < rect.left) { return 0; }
  if (x >= rect.right) { return 0; }
  if (y < rect.top) { return 0; }
  if (y >= rect.bottom) { return 0; }
  return 1;
}

export fn ui_clamp_i32(value: int32, lo: int32, hi: int32) -> int32 {
  if (value < lo) { return lo; }
  if (value > hi) { return hi; }
  return value;
}

export fn ui_scale(value: int32, dpi: int32) -> int32 {
  return (value * dpi + 48) / 96;
}

export fn ui_cstring_len(text: cstring) -> int32 {
  var len: int32 = 0;
  while (text[len] != 0) {
    len = len + 1;
  }
  return len;
}

export fn ui_default_theme() -> UiTheme {
  var theme: UiTheme;
  theme.background = ui_rgb(245, 247, 250);
  theme.surface = ui_rgb(255, 255, 255);
  theme.border = ui_rgb(204, 213, 224);
  theme.text = ui_rgb(31, 41, 55);
  theme.muted_text = ui_rgb(100, 116, 139);
  theme.accent = ui_rgb(37, 99, 235);
  theme.accent_text = ui_rgb(255, 255, 255);
  theme.danger = ui_rgb(220, 38, 38);
  return theme;
}

export fn ui_command_id(wparam: int64) -> uint32 {
  return ui_lo_word(wparam);
}

export fn ui_command_notify(wparam: int64) -> uint32 {
  return ui_hi_word(wparam);
}

export fn ui_size_width(lparam: int64) -> int32 {
  return (int32)(lparam & 0xFFFF);
}

export fn ui_size_height(lparam: int64) -> int32 {
  return (int32)((lparam >> 16) & 0xFFFF);
}

export fn ui_mouse_x(lparam: int64) -> int32 {
  var x: int32 = (int32)(lparam & 0xFFFF);
  if (x >= 32768) { return x - 65536; }
  return x;
}

export fn ui_mouse_y(lparam: int64) -> int32 {
  var y: int32 = (int32)((lparam >> 16) & 0xFFFF);
  if (y >= 32768) { return y - 65536; }
  return y;
}

// Lightweight layout helpers.
export fn ui_stack_vertical(x: int32, y: int32, width: int32, height: int32, gap: int32) -> UiLayoutCursor {
  var layout: UiLayoutCursor;
  layout.x = x;
  layout.y = y;
  layout.width = width;
  layout.height = height;
  layout.gap = gap;
  return layout;
}

export fn ui_stack_horizontal(x: int32, y: int32, width: int32, height: int32, gap: int32) -> UiLayoutCursor {
  return ui_stack_vertical(x, y, width, height, gap);
}

export fn ui_stack_next(layout: UiLayoutCursor*) -> UiRect {
  var rect: UiRect = ui_rect_xywh(layout->x, layout->y, layout->width, layout->height);
  layout->y = layout->y + layout->height + layout->gap;
  return rect;
}

export fn ui_stack_next_h(layout: UiLayoutCursor*) -> UiRect {
  var rect: UiRect = ui_rect_xywh(layout->x, layout->y, layout->width, layout->height);
  layout->x = layout->x + layout->width + layout->gap;
  return rect;
}

export fn ui_row_rect(parent: UiRect*, index: int32, row_height: int32, gap: int32) -> UiRect {
  var y: int32 = parent->top;
  var i: int32 = 0;
  while (i < index) {
    y = y + row_height + gap;
    i = i + 1;
  }
  return ui_make_rect(parent->left, y, parent->right, y + row_height);
}

export fn ui_column_rect(parent: UiRect*, index: int32, column_count: int32, gap: int32) -> UiRect {
  var usable_width: int32 = parent->right - parent->left;
  var gaps: int32 = column_count - 1;
  while (gaps > 0) {
    usable_width = usable_width - gap;
    gaps = gaps - 1;
  }

  var width: int32 = usable_width / column_count;
  var x: int32 = parent->left;
  var i: int32 = 0;
  while (i < index) {
    x = x + width + gap;
    i = i + 1;
  }
  return ui_rect_xywh(x, parent->top, width, parent->bottom - parent->top);
}

// Initialization and app shell.
export fn ui_init() -> int32 {
  if (ui_class_registered != 0) {
    return 1;
  }

  ui_app_instance = Ui_GetModuleHandleA(0);
  if (ui_app_instance == NULL_HANDLE()) {
    return 0;
  }

  var wnd_class: UiWndClassEx;
  wnd_class.cb_size = 80;
  wnd_class.style = UI_CS_HREDRAW() | UI_CS_VREDRAW() | UI_CS_DBLCLKS();
  wnd_class.wnd_proc = &ui_trampoline_window_proc;
  wnd_class.cls_extra = 0;
  wnd_class.wnd_extra = 0;
  wnd_class.instance = ui_app_instance;
  wnd_class.icon = 0;
  wnd_class.cursor = Ui_LoadCursorA(0, (cstring)(int64)UI_IDC_ARROW());
  wnd_class.background = (int64)(UI_COLOR_WINDOW() + 1);
  wnd_class.menu_name = 0;
  wnd_class.class_name = cstr(UI_CLASS_NAME);
  wnd_class.icon_sm = 0;

  if (Ui_RegisterClassExA(&wnd_class) == 0) {
    return 0;
  }

  ui_class_registered = 1;
  return 1;
}

export fn ui_shutdown() {
  if (ui_class_registered == 0) {
    return;
  }
  Ui_UnregisterClassA(cstr(UI_CLASS_NAME), ui_app_instance);
  ui_class_registered = 0;
}

fn ui_trampoline_window_proc(hwnd: int64, msg: uint32, wparam: int64, lparam: int64) -> int64 {
  if (msg == UI_WM_CREATE()) {
    var create_params: int64 = *((int64*)lparam);
    if (create_params != 0) {
      Ui_SetWindowLongPtrA(hwnd, UI_GWLP_USERDATA(), create_params);
    }
  }

  var stored: int64 = Ui_GetWindowLongPtrA(hwnd, UI_GWLP_USERDATA());
  if (stored != 0) {
    var proc: fn(int64, uint32, int64, int64) -> int64 = (fn(int64, uint32, int64, int64) -> int64)stored;
    return proc(hwnd, msg, wparam, lparam);
  }

  if (msg == UI_WM_DESTROY()) {
    ui_quit(0);
    return 0;
  }
  return Ui_DefWindowProcA(hwnd, msg, wparam, lparam);
}

// Window lifecycle.
export fn ui_window_create(title: cstring, x: int32, y: int32, width: int32, height: int32, proc: fn(int64, uint32, int64, int64) -> int64) -> int64 {
  if (ui_init() == 0) {
    return 0;
  }

  var proc_addr: int64 = (int64)proc;
  return Ui_CreateWindowExA(
    UI_WS_EX_APPWINDOW(),
    cstr(UI_CLASS_NAME),
    title,
    UI_WS_OVERLAPPEDWINDOW() | UI_WS_CLIPCHILDREN(),
    x,
    y,
    width,
    height,
    0,
    0,
    ui_app_instance,
    (cstring)proc_addr
  );
}

export fn ui_window_create_config(config: UiWindowConfig, proc: fn(int64, uint32, int64, int64) -> int64) -> int64 {
  return ui_window_create(config.title, config.x, config.y, config.width, config.height, proc);
}

export fn ui_window_create_centered(title: cstring, width: int32, height: int32, proc: fn(int64, uint32, int64, int64) -> int64) -> int64 {
  var screen_w: int32 = win32_get_system_metrics(SM_CXSCREEN());
  var screen_h: int32 = win32_get_system_metrics(SM_CYSCREEN());
  return ui_window_create(title, (screen_w - width) / 2, (screen_h - height) / 2, width, height, proc);
}

export fn ui_app_run(config: UiAppConfig) -> int32 {
  var hwnd: int64 = ui_window_create_centered(config.title, config.width, config.height, config.proc);
  if (hwnd == 0) {
    return 1;
  }
  ui_window_show(hwnd);
  return ui_run_message_loop();
}

export fn ui_window_show(hwnd: int64) {
  Ui_ShowWindow(hwnd, UI_SW_SHOW());
  Ui_UpdateWindow(hwnd);
  // RDW_INVALIDATE|RDW_ERASE|RDW_ALLCHILDREN|RDW_UPDATENOW: force child
  // controls (buttons, labels, etc.) to paint their initial frame.
  Ui_RedrawWindow(hwnd, 0, 0, 0x0185);
}

export fn ui_window_hide(hwnd: int64) {
  Ui_ShowWindow(hwnd, UI_SW_HIDE());
}

export fn ui_window_close(hwnd: int64) {
  Ui_DestroyWindow(hwnd);
}

export fn ui_window_set_title(hwnd: int64, title: cstring) {
  Ui_SetWindowTextA(hwnd, title);
}

export fn ui_window_get_title(hwnd: int64, buf: cstring, max_len: int32) -> int32 {
  return Ui_GetWindowTextA(hwnd, buf, max_len);
}

export fn ui_window_client_rect(hwnd: int64) -> UiRect {
  var rect: UiRect;
  if (Ui_GetClientRect(hwnd, &rect) == 0) {
    return ui_make_rect(0, 0, 0, 0);
  }
  return rect;
}

export fn ui_window_rect(hwnd: int64) -> UiRect {
  var rect: UiRect;
  if (Ui_GetWindowRect(hwnd, &rect) == 0) {
    return ui_make_rect(0, 0, 0, 0);
  }
  return rect;
}

export fn ui_client_width(hwnd: int64) -> int32 {
  return ui_rect_width(ui_window_client_rect(hwnd));
}

export fn ui_client_height(hwnd: int64) -> int32 {
  return ui_rect_height(ui_window_client_rect(hwnd));
}

export fn ui_window_move(hwnd: int64, x: int32, y: int32, width: int32, height: int32, repaint: int32) -> int32 {
  return Ui_MoveWindow(hwnd, x, y, width, height, repaint);
}

export fn ui_window_set_pos(hwnd: int64, x: int32, y: int32, width: int32, height: int32, flags: uint32) -> int32 {
  return Ui_SetWindowPos(hwnd, 0, x, y, width, height, flags | UI_SWP_NOZORDER());
}

export fn ui_window_invalidate(hwnd: int64) {
  Ui_InvalidateRect(hwnd, 0, 1);
}

export fn ui_window_invalidate_rect(hwnd: int64, rect: UiRect*) {
  Ui_InvalidateRect(hwnd, rect, 1);
}

export fn ui_set_user_data(hwnd: int64, value: int64) -> int64 {
  return Ui_SetWindowLongPtrA(hwnd, UI_GWLP_USERDATA(), value);
}

export fn ui_get_user_data(hwnd: int64) -> int64 {
  return Ui_GetWindowLongPtrA(hwnd, UI_GWLP_USERDATA());
}

export fn ui_def_window_proc(hwnd: int64, msg: uint32, wparam: int64, lparam: int64) -> int64 {
  return Ui_DefWindowProcA(hwnd, msg, wparam, lparam);
}

export fn ui_alert(owner: int64, title: cstring, text: cstring) -> int32 {
  return Ui_MessageBoxA(owner, text, title, MB_OK() | MB_ICONINFORMATION());
}

// Message loop and timers.
export fn ui_quit(exit_code: int32) {
  Ui_PostQuitMessage(exit_code);
}

export fn ui_run_message_loop() -> int32 {
  var msg: UiMsg;
  while (Ui_GetMessageA(&msg, 0, 0, 0) > 0) {
    Ui_TranslateMessage(&msg);
    Ui_DispatchMessageA(&msg);
  }
  return (int32)msg.wparam;
}

export fn ui_pump_messages() -> int32 {
  var msg: UiMsg;
  var had_message: int32 = 0;
  while (Ui_PeekMessageA(&msg, 0, 0, 0, UI_PM_REMOVE()) != 0) {
    had_message = 1;
    Ui_TranslateMessage(&msg);
    Ui_DispatchMessageA(&msg);
  }
  return had_message;
}

export fn ui_timer_start(hwnd: int64, timer_id: uint32, elapsed_ms: uint32) -> uint32 {
  return Ui_SetTimer(hwnd, timer_id, elapsed_ms, 0);
}

export fn ui_timer_stop(hwnd: int64, timer_id: uint32) -> int32 {
  return Ui_KillTimer(hwnd, timer_id);
}

// Drawing.
export fn ui_begin_paint(hwnd: int64, paint: UiPaintStruct*) -> int64 {
  return Ui_BeginPaint(hwnd, paint);
}

export fn ui_end_paint(hwnd: int64, paint: UiPaintStruct*) {
  Ui_EndPaint(hwnd, paint);
}

export fn ui_fill_rect(hdc: int64, rect: UiRect*, brush: int64) -> int32 {
  return Ui_FillRect(hdc, rect, brush);
}

export fn ui_fill_rect_color(hdc: int64, left: int32, top: int32, right: int32, bottom: int32, color: uint32) -> int32 {
  var rect: UiRect = ui_make_rect(left, top, right, bottom);
  return ui_fill_rect_color_rect(hdc, &rect, color);
}

export fn ui_fill_rect_color_rect(hdc: int64, rect: UiRect*, color: uint32) -> int32 {
  var brush: int64 = Ui_CreateSolidBrush(color);
  if (brush == 0) {
    return 0;
  }
  var result: int32 = Ui_FillRect(hdc, rect, brush);
  Ui_DeleteObject(brush);
  return result;
}

export fn ui_frame_rect_color(hdc: int64, rect: UiRect*, color: uint32) -> int32 {
  var brush: int64 = Ui_CreateSolidBrush(color);
  if (brush == 0) {
    return 0;
  }
  var result: int32 = Ui_FrameRect(hdc, rect, brush);
  Ui_DeleteObject(brush);
  return result;
}

export fn ui_draw_line(hdc: int64, x1: int32, y1: int32, x2: int32, y2: int32, color: uint32, width: int32) -> int32 {
  var pen: int64 = Ui_CreatePen(UI_PS_SOLID(), width, color);
  if (pen == 0) {
    return 0;
  }
  var old_pen: int64 = Ui_SelectObject(hdc, pen);
  Ui_MoveToEx(hdc, x1, y1, 0);
  var result: int32 = Ui_LineTo(hdc, x2, y2);
  Ui_SelectObject(hdc, old_pen);
  Ui_DeleteObject(pen);
  return result;
}

export fn ui_draw_rect_outline(hdc: int64, rect: UiRect*, color: uint32, width: int32) -> int32 {
  var pen: int64 = Ui_CreatePen(UI_PS_SOLID(), width, color);
  if (pen == 0) {
    return 0;
  }
  var old_pen: int64 = Ui_SelectObject(hdc, pen);
  var result: int32 = Ui_Rectangle(hdc, rect->left, rect->top, rect->right, rect->bottom);
  Ui_SelectObject(hdc, old_pen);
  Ui_DeleteObject(pen);
  return result;
}

export fn ui_draw_ellipse_outline(hdc: int64, rect: UiRect*, color: uint32, width: int32) -> int32 {
  var pen: int64 = Ui_CreatePen(UI_PS_SOLID(), width, color);
  if (pen == 0) {
    return 0;
  }
  var old_pen: int64 = Ui_SelectObject(hdc, pen);
  var result: int32 = Ui_Ellipse(hdc, rect->left, rect->top, rect->right, rect->bottom);
  Ui_SelectObject(hdc, old_pen);
  Ui_DeleteObject(pen);
  return result;
}

export fn ui_set_text_color(hdc: int64, color: uint32) {
  Ui_SetTextColor(hdc, color);
}

export fn ui_set_text_background(hdc: int64, color: uint32) {
  Ui_SetBkMode(hdc, UI_BKMODE_OPAQUE());
  Ui_SetBkColor(hdc, color);
}

export fn ui_set_text_transparent(hdc: int64) {
  Ui_SetBkMode(hdc, UI_BKMODE_TRANSPARENT());
}

export fn ui_draw_text(hdc: int64, x: int32, y: int32, text: cstring) -> int32 {
  Ui_SetBkMode(hdc, UI_BKMODE_TRANSPARENT());
  Ui_SetTextColor(hdc, ui_rgb(0, 0, 0));
  return Ui_TextOutA(hdc, x, y, text, ui_cstring_len(text));
}

export fn ui_draw_text_color(hdc: int64, x: int32, y: int32, text: cstring, text_color: uint32, bg_color: uint32) -> int32 {
  Ui_SetBkMode(hdc, UI_BKMODE_OPAQUE());
  Ui_SetBkColor(hdc, bg_color);
  Ui_SetTextColor(hdc, text_color);
  return Ui_TextOutA(hdc, x, y, text, ui_cstring_len(text));
}

export fn ui_draw_text_transparent(hdc: int64, x: int32, y: int32, text: cstring, text_color: uint32) -> int32 {
  Ui_SetBkMode(hdc, UI_BKMODE_TRANSPARENT());
  Ui_SetTextColor(hdc, text_color);
  return Ui_TextOutA(hdc, x, y, text, ui_cstring_len(text));
}

export fn ui_draw_text_rect(hdc: int64, rect: UiRect*, text: cstring, flags: uint32) -> int32 {
  Ui_SetBkMode(hdc, UI_BKMODE_TRANSPARENT());
  return Ui_DrawTextA(hdc, text, -1, rect, flags);
}

export fn ui_draw_text_rect_color(hdc: int64, rect: UiRect*, text: cstring, text_color: uint32, flags: uint32) -> int32 {
  Ui_SetBkMode(hdc, UI_BKMODE_TRANSPARENT());
  Ui_SetTextColor(hdc, text_color);
  return Ui_DrawTextA(hdc, text, -1, rect, flags);
}

export fn ui_create_font(height: int32, face: cstring, weight: int32) -> int64 {
  return Ui_CreateFontA(0 - height, 0, 0, 0, weight, 0, 0, 0, UI_DEFAULT_CHARSET(), UI_OUT_DEFAULT_PRECIS(), UI_CLIP_DEFAULT_PRECIS(), UI_CLEARTYPE_QUALITY(), UI_DEFAULT_PITCH(), face);
}

export fn ui_create_font_config(config: UiFontConfig) -> int64 {
  return Ui_CreateFontA(0 - config.height, 0, 0, 0, config.weight, (uint32)config.italic, (uint32)config.underline, 0, UI_DEFAULT_CHARSET(), UI_OUT_DEFAULT_PRECIS(), UI_CLIP_DEFAULT_PRECIS(), UI_CLEARTYPE_QUALITY(), UI_DEFAULT_PITCH(), config.face);
}

export fn ui_select_object(hdc: int64, obj: int64) -> int64 {
  return Ui_SelectObject(hdc, obj);
}

export fn ui_delete_object(obj: int64) -> int32 {
  return Ui_DeleteObject(obj);
}

export fn ui_get_white_brush() -> int64 {
  return Ui_GetStockObject(0);
}

export fn ui_get_system_brush(color_index: int32) -> int64 {
  return Ui_GetSysColorBrush(color_index);
}

export fn ui_get_system_color(color_index: int32) -> uint32 {
  return Ui_GetSysColor(color_index);
}

// Controls.
//
// This wrapper used to be load-bearing: the 12-argument Ui_CreateWindowExA call
// was believed to mislay its outgoing stack arguments when issued from a frame
// holding a by-value UiControlConfig, corrupting width and height so controls
// came out invisible.
//
// The argument passing was never at fault. The config arrived already broken:
// `config.rect = ui_rect_xywh(...)` assigned a returned aggregate into a struct
// field, and that path copied only the first machine word (see
// tests/test_struct_return_to_field.mettle). CreateWindowExA was faithfully
// given the garbage it was handed.
//
// The isolation is no longer required. It is kept because a single named helper
// for the raw extern call is worth having on its own.
fn ui_native_control(
  parent: int64,
  class_name: cstring,
  text: cstring,
  ex_style: uint32,
  style: uint32,
  x: int32,
  y: int32,
  w: int32,
  h: int32,
  control_id: int32) -> int64 {
  return Ui_CreateWindowExA(
    ex_style,
    class_name,
    text,
    style,
    x,
    y,
    w,
    h,
    parent,
    (int64)control_id,
    ui_app_instance,
    0
  );
}

export fn ui_control_create(parent: int64, config: UiControlConfig) -> int64 {
  return ui_native_control(
    parent,
    config.class_name,
    config.text,
    config.ex_style,
    UI_WS_CHILD() | UI_WS_VISIBLE() | config.style,
    config.rect.left,
    config.rect.top,
    ui_rect_width(config.rect),
    ui_rect_height(config.rect),
    config.control_id
  );
}

export fn ui_control_create_raw(parent: int64, class_name: cstring, text: cstring, rect: UiRect, style: uint32, ex_style: uint32, control_id: int32) -> int64 {
  return ui_native_control(
    parent,
    class_name,
    text,
    ex_style,
    UI_WS_CHILD() | UI_WS_VISIBLE() | style,
    rect.left,
    rect.top,
    ui_rect_width(rect),
    ui_rect_height(rect),
    control_id
  );
}

export fn ui_button_create(parent: int64, x: int32, y: int32, width: int32, height: int32, label: cstring, control_id: int32) -> int64 {
  return ui_control_create_raw(parent, cstr("BUTTON"), label, ui_rect_xywh(x, y, width, height), UI_WS_TABSTOP() | UI_BS_PUSHBUTTON(), 0, control_id);
}

