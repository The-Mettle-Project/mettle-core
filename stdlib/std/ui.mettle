  return (int32)Ui_SendMessageA(control, UI_LB_ADDSTRING(), 0, (int64)text);
}

export fn ui_listbox_clear(control: int64) {
  Ui_SendMessageA(control, UI_LB_RESETCONTENT(), 0, 0);
}

export fn ui_listbox_selected(control: int64) -> int32 {
  return (int32)Ui_SendMessageA(control, UI_LB_GETCURSEL(), 0, 0);
}

export fn ui_listbox_select(control: int64, index: int32) {
  Ui_SendMessageA(control, UI_LB_SETCURSEL(), index, 0);
}

export fn ui_combobox_add(control: int64, text: cstring) -> int32 {
  return (int32)Ui_SendMessageA(control, UI_CB_ADDSTRING(), 0, (int64)text);
}

export fn ui_combobox_clear(control: int64) {
  Ui_SendMessageA(control, UI_CB_RESETCONTENT(), 0, 0);
}

export fn ui_combobox_selected(control: int64) -> int32 {
  return (int32)Ui_SendMessageA(control, UI_CB_GETCURSEL(), 0, 0);
}

export fn ui_combobox_select(control: int64, index: int32) {
  Ui_SendMessageA(control, UI_CB_SETCURSEL(), index, 0);
}

// Menus.
export fn ui_menu_create() -> int64 {
  return Ui_CreateMenu();
}

export fn ui_menu_popup_create() -> int64 {
  return Ui_CreatePopupMenu();
}

export fn ui_menu_append_item(menu: int64, item_id: int32, text: cstring) -> int32 {
  return Ui_AppendMenuA(menu, UI_MF_STRING(), item_id, text);
}

export fn ui_menu_append_separator(menu: int64) -> int32 {
  return Ui_AppendMenuA(menu, UI_MF_SEPARATOR(), 0, 0);
}

export fn ui_menu_append_popup(menu: int64, popup: int64, text: cstring) -> int32 {
  return Ui_AppendMenuA(menu, UI_MF_POPUP(), popup, text);
}

export fn ui_window_set_menu(hwnd: int64, menu: int64) -> int32 {
  var result: int32 = Ui_SetMenu(hwnd, menu);
  Ui_DrawMenuBar(hwnd);
  return result;
}

export fn ui_menu_destroy(menu: int64) -> int32 {
  return Ui_DestroyMenu(menu);
}
