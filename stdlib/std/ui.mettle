  return ui_control_create_raw(parent, cstr("COMBOBOX"), cstr(""), ui_rect_xywh(x, y, width, height), UI_WS_TABSTOP() | UI_CBS_DROPDOWNLIST() | UI_CBS_AUTOHSCROLL(), 0, control_id);
}

export fn ui_control_set_text(control: int64, text: cstring) {
  Ui_SetWindowTextA(control, text);
}

export fn ui_control_get_text(control: int64, buf: cstring, max_len: int32) -> int32 {
  return Ui_GetWindowTextA(control, buf, max_len);
}

export fn ui_control_text_length(control: int64) -> int32 {
  return (int32)Ui_SendMessageA(control, UI_WM_GETTEXTLENGTH(), 0, 0);
}

export fn ui_control_move(control: int64, x: int32, y: int32, width: int32, height: int32) {
  Ui_MoveWindow(control, x, y, width, height, 1);
}

export fn ui_control_move_rect(control: int64, rect: UiRect) {
  Ui_MoveWindow(control, rect.left, rect.top, ui_rect_width(rect), ui_rect_height(rect), 1);
}

