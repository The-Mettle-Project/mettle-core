// Mettle standard library: native UI for Windows.
//
// A pragmatic Win32 framework layer for desktop apps: window lifecycle,
// message routing, common controls, menus, timers, layout helpers, colors,
// fonts, and immediate-mode drawing helpers. Programs should build with:
//
//   mettle --build --linker internal app.mettle -o app.exe

import "std/win32";
import "std/mem";
import "std/io";

// Core layout structs matching Win32 where required.
export struct UiRect {
  left: int32;
  top: int32;
  right: int32;
  bottom: int32;
}

export struct UiPoint {
  x: int32;
  y: int32;
}

export struct UiSize {
  width: int32;
  height: int32;
}

export struct UiInsets {
  left: int32;
  top: int32;
  right: int32;
  bottom: int32;
}

export struct UiMsg {
  hwnd: int64;
  message: uint32;
  wparam: int64;
  lparam: int64;
  time: uint32;
  pt: UiPoint;
}

export struct UiPaintStruct {
  hdc: int64;
  erase: int32;
  rc_paint: UiRect;
  restore: int32;
  inc_update: int32;
  reserved: uint8[32];
}

export struct UiWndClassEx {
  cb_size: uint32;
  style: uint32;
  wnd_proc: fn(int64, uint32, int64, int64) -> int64;
  cls_extra: int32;
  wnd_extra: int32;
  instance: int64;
  icon: int64;
  cursor: int64;
  background: int64;
  menu_name: cstring;
  class_name: cstring;
  icon_sm: int64;
}

export struct UiWindowConfig {
  title: cstring;
  x: int32;
  y: int32;
  width: int32;
  height: int32;
}

export struct UiAppConfig {
  title: cstring;
  width: int32;
  height: int32;
  proc: fn(int64, uint32, int64, int64) -> int64;
}

export struct UiControlConfig {
  class_name: cstring;
  text: cstring;
  rect: UiRect;
  style: uint32;
  ex_style: uint32;
  control_id: int32;
}

export struct UiLayoutCursor {
  x: int32;
  y: int32;
  width: int32;
  height: int32;
  gap: int32;
}

export struct UiTheme {
  background: uint32;
  surface: uint32;
  border: uint32;
  text: uint32;
  muted_text: uint32;
  accent: uint32;
  accent_text: uint32;
  danger: uint32;
}

export struct UiFontConfig {
  height: int32;
  weight: int32;
  italic: int32;
  underline: int32;
  face: cstring;
}

