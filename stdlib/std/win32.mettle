// Mettle standard library: native Win32 bindings.
//
// This module exposes a small, typed Win32 surface without requiring each
// program to repeat raw extern declarations. In --build --linker internal mode,
// common Win32 DLLs are probed directly by the native PE linker.

// Basic Win32 constants. They are functions because Mettle does not yet have
// top-level constant expressions.
export fn FALSE() -> int32 { return 0; }
export fn TRUE() -> int32 { return 1; }
export fn NULL_HANDLE() -> int64 { return 0; }
export fn INVALID_HANDLE_VALUE() -> int64 { return -1; }

export fn STD_INPUT_HANDLE() -> int32 { return -10; }
export fn STD_OUTPUT_HANDLE() -> int32 { return -11; }
export fn STD_ERROR_HANDLE() -> int32 { return -12; }

export fn INFINITE() -> uint32 { return 0xFFFFFFFF; }
export fn WAIT_OBJECT_0() -> uint32 { return 0; }
export fn WAIT_TIMEOUT() -> uint32 { return 258; }
export fn WAIT_FAILED() -> uint32 { return 0xFFFFFFFF; }

export fn MB_OK() -> uint32 { return 0; }
export fn MB_ICONINFORMATION() -> uint32 { return 64; }
export fn SM_CXSCREEN() -> int32 { return 0; }
export fn SM_CYSCREEN() -> int32 { return 1; }

export fn GENERIC_READ() -> uint32 { return 0x80000000; }
export fn GENERIC_WRITE() -> uint32 { return 0x40000000; }
export fn FILE_SHARE_READ() -> uint32 { return 1; }
export fn FILE_SHARE_WRITE() -> uint32 { return 2; }
export fn CREATE_NEW() -> uint32 { return 1; }
export fn CREATE_ALWAYS() -> uint32 { return 2; }
export fn OPEN_EXISTING() -> uint32 { return 3; }
export fn OPEN_ALWAYS() -> uint32 { return 4; }
export fn TRUNCATE_EXISTING() -> uint32 { return 5; }
export fn FILE_ATTRIBUTE_NORMAL() -> uint32 { return 128; }

// SYSTEMTIME from WinBase.h.
export struct Win32SystemTime {
  year: uint16;
  month: uint16;
  day_of_week: uint16;
  day: uint16;
  hour: uint16;
  minute: uint16;
  second: uint16;
  milliseconds: uint16;
}

// Kernel32.
export extern fn Win32_GetLastError() -> uint32 = "GetLastError";
export extern fn Win32_SetLastError(error_code: uint32) = "SetLastError";
export extern fn Win32_GetStdHandle(std_handle: int32) -> int64 = "GetStdHandle";
export extern fn Win32_GetCurrentProcess() -> int64 = "GetCurrentProcess";
export extern fn Win32_GetCurrentProcessId() -> uint32 = "GetCurrentProcessId";
export extern fn Win32_GetCurrentThreadId() -> uint32 = "GetCurrentThreadId";
export extern fn Win32_GetTickCount64() -> uint64 = "GetTickCount64";
export extern fn Win32_Sleep(milliseconds: uint32) = "Sleep";
export extern fn Win32_CloseHandle(handle: int64) -> int32 = "CloseHandle";
export extern fn Win32_WaitForSingleObject(handle: int64, milliseconds: uint32) -> uint32 = "WaitForSingleObject";
export extern fn Win32_GetSystemTime(time: Win32SystemTime*) = "GetSystemTime";
export extern fn Win32_CreateFileA(file_name: cstring, desired_access: uint32, share_mode: uint32, security_attributes: cstring, creation_disposition: uint32, flags_and_attributes: uint32, template_file: int64) -> int64 = "CreateFileA";
export extern fn Win32_ReadFile(file: int64, buffer: cstring, bytes_to_read: uint32, bytes_read: uint32*, overlapped: cstring) -> int32 = "ReadFile";
export extern fn Win32_WriteFile(file: int64, buffer: cstring, bytes_to_write: uint32, bytes_written: uint32*, overlapped: cstring) -> int32 = "WriteFile";

// User32.
export extern fn Win32_GetSystemMetrics(index: int32) -> int32 = "GetSystemMetrics";
export extern fn Win32_MessageBoxA(owner: int64, text: cstring, caption: cstring, kind: uint32) -> int32 = "MessageBoxA";

export fn win32_last_error() -> uint32 {
  return Win32_GetLastError();
}

export fn win32_set_last_error(error_code: uint32) {
  Win32_SetLastError(error_code);
}

export fn win32_get_std_handle(std_handle: int32) -> int64 {
  return Win32_GetStdHandle(std_handle);
}

export fn win32_stdout() -> int64 {
  return Win32_GetStdHandle(STD_OUTPUT_HANDLE());
}

export fn win32_stderr() -> int64 {
  return Win32_GetStdHandle(STD_ERROR_HANDLE());
}

export fn win32_stdin() -> int64 {
  return Win32_GetStdHandle(STD_INPUT_HANDLE());
}

export fn win32_is_invalid_handle(handle: int64) -> int32 {
  if (handle == NULL_HANDLE()) {
    return TRUE();
  }
  if (handle == INVALID_HANDLE_VALUE()) {
    return TRUE();
  }
  return FALSE();
}

export fn win32_close_handle(handle: int64) -> int32 {
  if (win32_is_invalid_handle(handle) != FALSE()) {
    return FALSE();
  }
  return Win32_CloseHandle(handle);
}

export fn win32_sleep_ms(milliseconds: uint32) {
  Win32_Sleep(milliseconds);
}

export fn win32_tick_count64() -> uint64 {
  return Win32_GetTickCount64();
}

export fn win32_get_current_process_id() -> uint32 {
  return Win32_GetCurrentProcessId();
}

export fn win32_get_current_thread_id() -> uint32 {
  return Win32_GetCurrentThreadId();
}

export fn win32_wait(handle: int64, timeout_ms: uint32) -> uint32 {
  return Win32_WaitForSingleObject(handle, timeout_ms);
}

export fn win32_wait_forever(handle: int64) -> uint32 {
  return Win32_WaitForSingleObject(handle, INFINITE());
}

export fn win32_get_system_time(out_time: Win32SystemTime*) {
  Win32_GetSystemTime(out_time);
}

export fn win32_get_system_metrics(index: int32) -> int32 {
  return Win32_GetSystemMetrics(index);
}

export fn win32_message_box(text: cstring, caption: cstring) -> int32 {
  return Win32_MessageBoxA(NULL_HANDLE(), text, caption, MB_OK());
}

export fn win32_message_box_info(text: cstring, caption: cstring) -> int32 {
  return Win32_MessageBoxA(NULL_HANDLE(), text, caption, MB_OK() | MB_ICONINFORMATION());
}

export fn win32_create_file_read(path: cstring) -> int64 {
  return Win32_CreateFileA(path, GENERIC_READ(), FILE_SHARE_READ(), 0, OPEN_EXISTING(), FILE_ATTRIBUTE_NORMAL(), 0);
}

export fn win32_create_file_write(path: cstring) -> int64 {
  return Win32_CreateFileA(path, GENERIC_WRITE(), 0, 0, CREATE_ALWAYS(), FILE_ATTRIBUTE_NORMAL(), 0);
}

export fn win32_read_file(file: int64, buffer: cstring, bytes_to_read: uint32, bytes_read: uint32*) -> int32 {
  return Win32_ReadFile(file, buffer, bytes_to_read, bytes_read, 0);
}

export fn win32_write_file(file: int64, buffer: cstring, bytes_to_write: uint32, bytes_written: uint32*) -> int32 {
  return Win32_WriteFile(file, buffer, bytes_to_write, bytes_written, 0);
}

export fn win32_write_stdout(buffer: cstring, bytes_to_write: uint32) -> int32 {
  var written: uint32 = 0;
  return Win32_WriteFile(win32_stdout(), buffer, bytes_to_write, &written, 0);
}

export fn win32_write_stderr(buffer: cstring, bytes_to_write: uint32) -> int32 {
  var written: uint32 = 0;
  return Win32_WriteFile(win32_stderr(), buffer, bytes_to_write, &written, 0);
}
